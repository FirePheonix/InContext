# Shared database
# Set these in Vercel. `DATABASE_URL` should also be set in Railway.
DATABASE_URL="postgresql://app_user:app_password@your-pooled-host/incontext?schema=public"
DIRECT_URL="postgresql://app_user:app_password@your-direct-host/incontext?schema=public"

# Auth.js / Google OAuth
# Vercel-only server envs. Do not expose these as NEXT_PUBLIC_ vars.
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"
AUTH_TRUST_HOST="true"

# MCP / git execution
# Railway-only for the HTTP MCP server unless you also run MCP locally.
DIRECT_GIT_COMMITS_ENABLED="false"
GIT_PROJECTS_ROOT="E:\\context-git"
MCP_PORT="8787"
MCP_AUTH_TOKEN="replace-with-a-long-random-bearer-token"
MCP_ALLOWED_ORIGINS="https://your-vercel-domain"
